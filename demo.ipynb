   "source": [
    "# In any new cell, or a new notebook entirely\n",
    "from tagger import viterbi\n",
    "\n",
    "sentence = \"The stock market crashed badly yesterday\".split()\n",
    "tags, score = viterbi(sentence)\n",
    "\n",
    "for word, tag in zip(sentence, tags):\n",
    "    print(f\"{word:15} → {tag}\")"
   ]
  }
